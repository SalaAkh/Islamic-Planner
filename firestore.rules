rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Make sure users can only read and write their own documents, and only specific allowed data keys
    match /users/{userId}/data/{document} {
      allow read, delete: if request.auth != null && request.auth.uid == userId;
      // Allow create/update only if it matches our expected document keys
      allow create, update: if request.auth != null 
                             && request.auth.uid == userId
                             && (
                               document == 'goals' || 
                               document == 'settings_ai' || 
                               document == 'board_state' ||
                               document == 'board_drawing' ||
                               document == 'events' ||
                               document.matches('^day_.*') || 
                               document.matches('^notes_.*')
                             );
    }

    // Activity log — each user can only read/write their own log entries
    match /users/{userId}/activity_log/{logId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Reminders — each user can manage their own reminders
    match /users/{userId}/reminders/{reminderId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // FCM Tokens for Push Notifications
    match /users/{userId}/fcmTokens/{tokenId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
